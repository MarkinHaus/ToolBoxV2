# syntax=docker/dockerfile:1.4
# ============================================================================
# ToolBoxV2 — Manifest-Based Minimal Docker Image
# ============================================================================
#
# Features via BUILD-ARGS:
#   FEATURE_CLI=1      CLI (prompt_toolkit, rich, readchar)
#   FEATURE_WEB=1      Web (starlette, uvicorn, httpx)
#   FEATURE_DESKTOP=1  Desktop GUI (PyQt6)
#   FEATURE_EXOTIC=1   Data Science (scipy, matplotlib, pandas)
#   FEATURE_ISAA=1     AI Agents (litellm, langchain, groq)
#
# Build:
#   docker build --build-arg FEATURE_CLI=1 --build-arg FEATURE_WEB=1 \
#     -f Dockerfile.toolbox -t toolboxv2:latest .
#
# ============================================================================

# -- Build arguments ---------------------------------------------------------
ARG PYTHON_VERSION=3.11
ARG FEATURE_CLI=0
ARG FEATURE_WEB=0
ARG FEATURE_DESKTOP=0
ARG FEATURE_EXOTIC=0
ARG FEATURE_ISAA=0

# ============================================================================
# STAGE 1: Filter requirements based on active features
# ============================================================================
FROM python:${PYTHON_VERSION}-alpine AS requirements-generator

WORKDIR /app
COPY docker/filter_requirements.py /tmp/filter_requirements.py
COPY requirements.txt .

ARG FEATURE_CLI
ARG FEATURE_WEB
ARG FEATURE_DESKTOP
ARG FEATURE_EXOTIC
ARG FEATURE_ISAA

ENV FEATURE_CLI=${FEATURE_CLI} \
    FEATURE_WEB=${FEATURE_WEB} \
    FEATURE_DESKTOP=${FEATURE_DESKTOP} \
    FEATURE_EXOTIC=${FEATURE_EXOTIC} \
    FEATURE_ISAA=${FEATURE_ISAA}

RUN python3 /tmp/filter_requirements.py

# ============================================================================
# STAGE 2: Python dependency builder
# ============================================================================
FROM python:${PYTHON_VERSION}-alpine AS py-builder

# Build deps for compiled wheels (musl)
RUN apk add --no-cache \
    gcc g++ musl-dev libffi-dev openssl-dev git curl \
    # ZMQ
    zeromq-dev \
    # For packages that need linux-headers
    linux-headers

RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
RUN pip install --no-cache-dir --upgrade pip setuptools wheel

COPY --from=requirements-generator /app/requirements-final.txt /tmp/requirements-final.txt
COPY --from=requirements-generator /app/active-features.txt /tmp/active-features.txt

RUN echo "=== Building with features: $(cat /tmp/active-features.txt) ===" && \
    pip install --no-cache-dir --prefer-binary -r /tmp/requirements-final.txt

# ============================================================================
# STAGE 3: Node.js builder (only when FEATURE_WEB=1)
# ============================================================================
FROM node:20-alpine AS node-builder

WORKDIR /app/toolboxv2

# Copy package files first for cache
COPY toolboxv2/package.json toolboxv2/package-lock.json* ./
COPY toolboxv2/web/package.json toolboxv2/web/package-lock.json* ./web/

# Install deps (ci for reproducibility, omit dev for prod)
RUN npm ci --omit=dev 2>/dev/null || npm install --omit=dev && \
    cd web && (npm ci --omit=dev 2>/dev/null || npm install --omit=dev)

# Copy source and build
COPY toolboxv2/web/ ./web/
COPY toolboxv2/index.js toolboxv2/index.html toolboxv2/favicon.ico ./
RUN npx webpack --mode production 2>/dev/null || true

# ============================================================================
# STAGE 4: Runtime — minimal final image
# ============================================================================
FROM python:${PYTHON_VERSION}-alpine AS runtime

LABEL maintainer="ToolBoxV2" \
      description="ToolBoxV2 — Manifest-Based Minimal Image"

# Build info labels
ARG FEATURE_CLI=0
ARG FEATURE_WEB=0
ARG FEATURE_DESKTOP=0
ARG FEATURE_EXOTIC=0
ARG FEATURE_ISAA=0
LABEL features.cli=${FEATURE_CLI} \
      features.web=${FEATURE_WEB} \
      features.desktop=${FEATURE_DESKTOP} \
      features.exotic=${FEATURE_EXOTIC} \
      features.isaa=${FEATURE_ISAA}

# Runtime-only system deps
RUN apk add --no-cache \
    curl ca-certificates \
    # ZMQ runtime lib
    libzmq \
    # Git (needed for some TB operations)
    git \
    # Tini for proper PID 1 signal handling
    tini

# Copy venv from builder
COPY --from=py-builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH" \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

# Create user
RUN adduser -D -s /bin/sh toolbox && \
    mkdir -p /app /data /home/toolbox/.config && \
    chown -R toolbox:toolbox /home/toolbox /data

WORKDIR /app

# Copy package metadata (changes rarely → cached)
COPY setup.py requirements.txt README.md setup.cfg MANIFEST.in pyproject.toml ./

# Copy ToolBoxV2 source
COPY toolboxv2/ ./toolboxv2/

# Copy built web assets from node builder (only dist, not node_modules)
COPY --from=node-builder /app/toolboxv2/dist/ ./toolboxv2/dist/

# Copy manifest
COPY tb-manifest.yaml ./

# Copy active features info
COPY --from=requirements-generator /app/active-features.txt /tmp/active-features.txt

# Install TB (no-deps since venv already has everything)
RUN pip install --no-build-isolation --no-deps -e . && \
    # Clean up pip cache
    rm -rf /root/.cache/pip

USER toolbox
WORKDIR /home/toolbox

# Default command
ENTRYPOINT ["tini", "--"]
CMD ["tb", "workers", "start"]

EXPOSE 8000 8001

VOLUME /data

HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')" || exit 1
