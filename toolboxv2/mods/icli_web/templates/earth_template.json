{
  "earth_globe": {
    "template": "html",
    "category": "custom",
    "description": "Theme-aware satellite-view Earth sphere: procedural continents, day/night lighting, atmosphere glow, terminator line. Drag to rotate, scroll to zoom, buttons for pause / reset / night mode. Pure Canvas2D, no external libraries. Uses rgba() colors so it renders correctly regardless of CSS --primary color format.",
    "content": {
      "title": "Earth",
      "trusted": true,
      "html": "<div style=\"display:flex; flex-direction:column; gap:8px; align-items:center;\">\n  <div id=\"globe-wrap-{uid}\" style=\"position:relative; width:340px; height:340px;\">\n    <canvas id=\"globe-atmo-{uid}\" width=\"340\" height=\"340\"\n            style=\"position:absolute; inset:0; pointer-events:none;\"></canvas>\n    <canvas id=\"globe-canvas-{uid}\" width=\"340\" height=\"340\"\n            style=\"position:relative; border:2px solid var(--ink); border-radius:50%; background:var(--paper-sunken); cursor:grab;\"></canvas>\n  </div>\n  <div style=\"display:flex; gap:6px; flex-wrap:wrap; justify-content:center;\">\n    <button class=\"pc-ctrl\" data-globe-act=\"pause-{uid}\">pause</button>\n    <button class=\"pc-ctrl\" data-globe-act=\"reset-{uid}\">reset</button>\n    <button class=\"pc-ctrl\" data-globe-act=\"night-{uid}\">night</button>\n    <span style=\"font-family:var(--font-display); font-size:10px; color:var(--ink-muted); align-self:center; letter-spacing:1px;\">DRAG · SCROLL</span>\n  </div>\n</div>\n<script>\n(function(){\n  var uid = \"{uid}\";\n  var canvas = document.getElementById(\"globe-canvas-\" + uid);\n  if (!canvas || canvas.dataset.wired) return;\n  canvas.dataset.wired = \"1\";\n  var atmoCanvas = document.getElementById(\"globe-atmo-\" + uid);\n  var ctx = canvas.getContext(\"2d\");\n  var atmoCtx = atmoCanvas.getContext(\"2d\");\n  var W = canvas.width, H = canvas.height;\n  var cx = W/2, cy = H/2;\n  var R = Math.min(W, H) * 0.42;\n  var rx = 0.3, ry = 0, running = true, nightMode = false;\n  var sunAngle = 0;\n\n  // Read theme colors from CSS vars at draw-time so theme toggle is live.\n  // We never return oklch() strings because Canvas addColorStop can't\n  // parse them when we want to apply alpha — always produce rgba().\n  function themeColors() {\n    var cs = getComputedStyle(document.documentElement);\n    var bg = (cs.getPropertyValue(\"--paper-bg\") || \"\").trim();\n    var dark = bg === \"#000\" || bg === \"#000000\" || bg.indexOf(\"rgb(0\") === 0;\n    // Build a concrete fallback color palette we *know* is rgba-safe.\n    // We don't try to use var(--primary) in canvas — oklch() is not\n    // supported in gradient stops across all browsers. Pick our own.\n    return {\n      dark: dark,\n      oceanDay:   \"#5db4e0\",\n      oceanNight: \"#0a1525\",\n      landDayR: 95, landDayG: 140, landDayB: 70,\n      landNight: \"rgba(90,95,110,\",    // alpha appended at use\n      lights:    \"rgba(255,210,120,\",  // night-mode city lights\n      glow:      dark ? \"rgba(90,160,220,\" : \"rgba(120,180,240,\",\n      grid:      dark ? \"rgba(255,255,255,0.08)\" : \"rgba(0,0,0,0.15)\",\n      terminator:\"rgba(255,200,100,0.25)\",\n    };\n  }\n\n  // Procedural \"continent\" mask. Returns -1..1 elevation-ish value at\n  // (latRad, lngRad). Stable, no randomness — same coords always give\n  // the same value so the globe surface is consistent across frames.\n  function landAt(lat, lng) {\n    var n1 = Math.sin(lat * 2.3 + lng * 1.7) * 0.5;\n    var n2 = Math.cos(lat * 4.1 - lng * 3.3) * 0.25;\n    var n3 = Math.sin(lng * 5.7 + Math.cos(lat * 2) * 3) * 0.15;\n    var latWeight = 1 - Math.abs(Math.sin(lat)) * 0.3;\n    return (n1 + n2 + n3) * latWeight;\n  }\n\n  function rot(p, ax, ay) {\n    var x = p[0], y = p[1], z = p[2];\n    var c = Math.cos(ay), s = Math.sin(ay);\n    var x2 = x * c - z * s, z2 = x * s + z * c;\n    x = x2; z = z2;\n    c = Math.cos(ax); s = Math.sin(ax);\n    var y2 = y * c - z * s, z3 = y * s + z * c;\n    return [x, y2, z3];\n  }\n\n  function drawAtmosphere(col) {\n    atmoCtx.clearRect(0, 0, W, H);\n    var grad = atmoCtx.createRadialGradient(cx, cy, R*0.95, cx, cy, R*1.15);\n    // Use rgba() so Canvas accepts the alpha — oklch() doesn't work here\n    grad.addColorStop(0, col.glow + (col.dark ? \"0.35)\" : \"0.22)\"));\n    grad.addColorStop(1, \"rgba(0,0,0,0)\");\n    atmoCtx.fillStyle = grad;\n    atmoCtx.fillRect(0, 0, W, H);\n  }\n\n  function draw() {\n    var col = themeColors();\n    var dark = col.dark || nightMode;\n    drawAtmosphere(col);\n    ctx.clearRect(0, 0, W, H);\n\n    // Base ocean disc\n    ctx.beginPath();\n    ctx.arc(cx, cy, R, 0, Math.PI * 2);\n    ctx.fillStyle = dark ? col.oceanNight : col.oceanDay;\n    ctx.fill();\n\n    var STEP_LAT = 3, STEP_LNG = 3;\n    var sunDir = [Math.cos(sunAngle), 0, Math.sin(sunAngle)];\n    for (var lat = -90; lat <= 90; lat += STEP_LAT) {\n      var latR = lat * Math.PI / 180;\n      for (var lng = 0; lng < 360; lng += STEP_LNG) {\n        var lngR = lng * Math.PI / 180;\n        var p = [\n          Math.cos(latR) * Math.cos(lngR),\n          Math.sin(latR),\n          Math.cos(latR) * Math.sin(lngR)\n        ];\n        var elev = landAt(latR, lngR);\n        var rp = rot(p, rx, ry);\n        var x = rp[0], y = rp[1], z = rp[2];\n        if (z < 0) continue;\n\n        var lit = Math.max(0, sunDir[0]*x + sunDir[2]*z) * 0.9 + 0.1;\n        var sx = cx + x * R;\n        var sy = cy + y * R;\n        var pxSize = 3;\n\n        if (elev > 0.1) {\n          if (dark) {\n            // Sparse city lights on lit-ish land (deterministic \"random\")\n            if (lit > 0.35 && elev > 0.25 && ((lng*7 + lat*11) % 23) < 2) {\n              ctx.fillStyle = col.lights + \"1)\";\n              ctx.fillRect(sx - 1, sy - 1, 2, 2);\n            } else {\n              ctx.fillStyle = col.landNight + (lit * 0.6) + \")\";\n              ctx.fillRect(sx - pxSize/2, sy - pxSize/2, pxSize, pxSize);\n            }\n          } else {\n            var r = Math.round(col.landDayR + lit * 40);\n            var g = Math.round(col.landDayG + lit * 40);\n            var b = Math.round(col.landDayB + lit * 30);\n            ctx.fillStyle = \"rgb(\" + r + \",\" + g + \",\" + b + \")\";\n            ctx.fillRect(sx - pxSize/2, sy - pxSize/2, pxSize, pxSize);\n          }\n        } else if (dark) {\n          if (lit < 0.15) continue;\n          ctx.fillStyle = \"rgba(20,30,60,\" + (lit * 0.4) + \")\";\n          ctx.fillRect(sx - pxSize/2, sy - pxSize/2, pxSize, pxSize);\n        } else {\n          var bb = Math.round(140 + lit * 80);\n          var gg = Math.round(160 + lit * 40);\n          ctx.fillStyle = \"rgb(90,\" + gg + \",\" + bb + \")\";\n          ctx.fillRect(sx - pxSize/2, sy - pxSize/2, pxSize, pxSize);\n        }\n      }\n    }\n\n    // Lat/lng grid overlay (subtle)\n    ctx.strokeStyle = col.grid;\n    ctx.lineWidth = 1;\n    for (var glat = -60; glat <= 60; glat += 30) {\n      ctx.beginPath();\n      var first = true;\n      for (var glng = 0; glng <= 360; glng += 6) {\n        var lR = glat * Math.PI/180, nR = glng * Math.PI/180;\n        var rp2 = rot([\n          Math.cos(lR) * Math.cos(nR),\n          Math.sin(lR),\n          Math.cos(lR) * Math.sin(nR)\n        ], rx, ry);\n        if (rp2[2] < 0) { first = true; continue; }\n        var gx = cx + rp2[0] * R, gy = cy + rp2[1] * R;\n        if (first) { ctx.moveTo(gx, gy); first = false; }\n        else       { ctx.lineTo(gx, gy); }\n      }\n      ctx.stroke();\n    }\n\n    // Terminator line (only in light mode, where it reads as sunset glow)\n    if (!dark) {\n      ctx.strokeStyle = col.terminator;\n      ctx.lineWidth = 2;\n      ctx.beginPath();\n      var tfirst = true;\n      for (var tlat = -90; tlat <= 90; tlat += 3) {\n        var tlatR = tlat * Math.PI/180;\n        var tLng = sunAngle + Math.PI/2;\n        var trp = rot([\n          Math.cos(tlatR) * Math.cos(tLng),\n          Math.sin(tlatR),\n          Math.cos(tlatR) * Math.sin(tLng)\n        ], rx, ry);\n        if (trp[2] < 0) { tfirst = true; continue; }\n        var tsx = cx + trp[0] * R, tsy = cy + trp[1] * R;\n        if (tfirst) { ctx.moveTo(tsx, tsy); tfirst = false; }\n        else        { ctx.lineTo(tsx, tsy); }\n      }\n      ctx.stroke();\n    }\n  }\n\n  function loop() {\n    if (running) {\n      ry += 0.004;\n      sunAngle -= 0.002;\n    }\n    draw();\n    requestAnimationFrame(loop);\n  }\n\n  var dragging = false, lx = 0, ly = 0;\n  canvas.addEventListener(\"mousedown\", function(e) {\n    dragging = true; lx = e.clientX; ly = e.clientY;\n    canvas.style.cursor = \"grabbing\";\n  });\n  window.addEventListener(\"mouseup\", function() {\n    dragging = false; canvas.style.cursor = \"grab\";\n  });\n  window.addEventListener(\"mousemove\", function(e) {\n    if (!dragging) return;\n    ry += (e.clientX - lx) * 0.006;\n    rx -= (e.clientY - ly) * 0.006;\n    rx = Math.max(-Math.PI/2, Math.min(Math.PI/2, rx));\n    lx = e.clientX; ly = e.clientY;\n  });\n  canvas.addEventListener(\"wheel\", function(e) {\n    e.preventDefault();\n    R = Math.max(80, Math.min(160, R - e.deltaY * 0.1));\n  }, { passive: false });\n\n  document.querySelector('[data-globe-act=\"pause-' + uid + '\"]').onclick = function() {\n    running = !running;\n  };\n  document.querySelector('[data-globe-act=\"reset-' + uid + '\"]').onclick = function() {\n    rx = 0.3; ry = 0; R = Math.min(W, H) * 0.42; sunAngle = 0;\n  };\n  document.querySelector('[data-globe-act=\"night-' + uid + '\"]').onclick = function() {\n    nightMode = !nightMode;\n  };\n  loop();\n})();\n</script>"
    }
  }
}
